{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "pnpm": "10.33.1",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "pnpm": "10.33.1",
      "prebuildCommand": "cd ../.. && pnpm install && cd apps/mobile",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "pnpm": "10.33.1",
      "prebuildCommand": "cd ../.. && pnpm install && cd apps/mobile"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "khanshaheroze@gmail.com",
        "ascAppId": "placeholder",
        "appleTeamId": "placeholder"
      },
      "android": {
        "serviceAccountKeyPath": "./google-services.json",
        "track": "internal"
      }
    }
  }
}
